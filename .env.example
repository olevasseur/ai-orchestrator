# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# Required: OpenAI API key for the planner
OPENAI_API_KEY=sk-...

# Optional overrides (all have defaults in config.yaml)
OPENAI_MODEL=gpt-5.4
EXECUTOR_MODE=cli     # cli | demo

# AWS profile for Cost Explorer reconciliation (SSO-based)
# AWS_PROFILE=valiant-sso-readonly

# Claude model for tiny_loop iterations (e.g. sonnet, opus, claude-sonnet-4-6; unset = default)
# CLAUDE_MODEL=sonnet

# Claude effort level for tiny_loop iterations (auto if unset)
# CLAUDE_EFFORT=high
